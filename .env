# ============================================================
# BabyLLM Configuration
# ============================================================
# REQUIRED: Get your free API key from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: Change the LLM model (Groq-hosted models)
# Options: llama3-8b-8192, llama3-70b-8192, mixtral-8x7b-32768, gemma2-9b-it
MODEL_NAME=llama3-8b-8192

# Optional: Change the embedding model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Optional: Tune retrieval
TOP_K=5
TEMPERATURE=0.4
SIMILARITY_THRESHOLD=0.35

# Data persistence path (inside container)
DB_PATH=/data/baby_faiss
